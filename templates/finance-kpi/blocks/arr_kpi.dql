block "ARR KPI" {
    domain = "finance"
    type = "custom"
    description = "Simple ARR KPI block backed by local CSV sample data"
    owner = "dql-example"
    tags = ["finance", "kpi", "local-data"]

    query = """
        SELECT SUM(amount) AS arr_total
        FROM read_csv_auto('./data/revenue.csv')
    """

    visualization {
        chart = "kpi"
        y = arr_total
    }

    tests {
        assert row_count > 0
    }
}
