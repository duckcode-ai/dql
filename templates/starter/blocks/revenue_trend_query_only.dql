block "Revenue Trend Query" {
    domain = "revenue"
    type = "chart.line"
    description = "Starter query-only block for monthly revenue trends"
    tags = ["starter", "revenue", "query-only"]
    owner = "template"

    query = """
        SELECT
            DATE_TRUNC('month', recognized_at) AS revenue_month,
            SUM(amount) AS total_revenue
        FROM fct_revenue
        GROUP BY 1
        ORDER BY 1
    """

    tests {
        assert row_count > 0
    }
}
