{
  "Dashboard": {
    "prefix": "dql-dashboard",
    "body": [
      "dashboard \"${1:Revenue Overview}\" {",
      "  chart.line(",
      "    SELECT ${2:order_date}, ${3:SUM(revenue)} as ${4:total}",
      "    FROM ${5:orders}",
      "    GROUP BY ${2:order_date},",
      "    x = ${2:order_date},",
      "    y = ${4:total},",
      "    title = \"${6:Revenue Trend}\"",
      "  )",
      "}"
    ],
    "description": "Create a dashboard with a line chart"
  },
  "Domain": {
    "prefix": "dql-domain",
    "body": [
      "domain \"${1:Customer}\" {",
      "  owner = \"${2:customer-analytics}\"",
      "  businessOwner = \"${3:Customer Success}\"",
      "  boundedContext = \"${4:Customer identity, lifecycle, activity, value, and retention}\"",
      "  sourceSystems = [\"${5:crm}\", \"${6:orders}\"]",
      "  primaryTerms = [\"${1:Customer}\"]",
      "  reviewCadence = \"${7:monthly}\"",
      "  tags = [\"${8:customer}\"]",
      "}"
    ],
    "description": "Create a first-class DQL business domain"
  },
  "Block": {
    "prefix": "dql-block",
    "body": [
      "block \"${1:Customer Orders Rollup}\" {",
      "  domain = \"${2:Customer}\"",
      "  type = \"custom\"",
      "  status = \"draft\"",
      "  description = \"${3:Aggregates customer order activity to one row per customer}\"",
      "  owner = \"${4:customer-analytics}\"",
      "  tags = [\"${5:customer}\", \"${6:orders}\", \"review-required\"]",
      "  pattern = \"${7:entity_rollup}\"",
      "  grain = \"${8:customer_id}\"",
      "  entities = [\"${2:Customer}\"]",
      "  terms = [\"${2:Customer}\", \"${9:Total Orders}\"]",
      "  outputs = [\"${8:customer_id}\", \"${10:total_orders}\"]",
      "  dimensions = [\"${11:segment}\"]",
      "  allowedFilters = [\"${12:order_date}\", \"${11:segment}\"]",
      "  sourceSystems = [\"${13:orders}\"]",
      "  replacementFor = []",
      "  reviewCadence = \"${14:monthly}\"",
      "  llmContext = \"Use this draft only after review for questions about customer order activity at customer grain.\"",
      "",
      "  parameterPolicy {",
      "    ${15:start_date} = \"dynamic\"",
      "    ${16:segment} = \"optional\"",
      "  }",
      "",
      "  filterBindings {",
      "    ${17:date_range} = \"${12:order_date}\"",
      "    ${16:segment} = \"${11:segment}\"",
      "  }",
      "",
      "  query = \"\"\"",
      "    SELECT",
      "      ${8:customer_id},",
      "      COUNT(*) AS ${10:total_orders}",
      "    FROM ${13:orders}",
      "    GROUP BY ${8:customer_id}",
      "  \"\"\"",
      "",
      "  visualization {",
      "    chart = \"table\"",
      "  }",
      "",
      "  tests {",
      "    assert row_count > 0",
      "  }",
      "}"
    ],
    "description": "Create an enterprise-ready reusable DQL block"
  },
  "Business View": {
    "prefix": "dql-business-view",
    "body": [
      "business_view \"${1:Customer 360}\" {",
      "  domain = \"${2:Customer}\"",
      "  status = \"${3:draft}\"",
      "  description = \"${4:Complete customer view for retention and account review}\"",
      "  owner = \"${5:customer-analytics}\"",
      "  terms = [\"${6:Customer}\"]",
      "  businessOutcome = \"${7:Understand customer value, activity, and service risk}\"",
      "  decisionUse = \"${8:Account planning, churn review, expansion targeting}\"",
      "  reviewCadence = \"${9:weekly}\"",
      "",
      "  includes {",
      "    block \"${10:Customer Identity}\"",
      "    block \"${11:Customer Orders Rollup}\"",
      "    business_view \"${12:Customer Service Summary}\"",
      "  }",
      "}"
    ],
    "description": "Create a DQL business composition view"
  },
  "Term": {
    "prefix": "dql-term",
    "body": [
      "term \"${1:Customer}\" {",
      "  domain = \"${2:Customer}\"",
      "  type = \"${3:entity}\"",
      "  status = \"${4:draft}\"",
      "  description = \"${5:A person or account that can place orders or receive service}\"",
      "  owner = \"${6:customer-analytics}\"",
      "  tags = [\"${7:customer}\"]",
      "  identifiers = [\"${8:customer_id}\"]",
      "  synonyms = [\"${9:Account}\"]",
      "  businessOwner = \"${10:Customer Success}\"",
      "  businessRules = [\"${11:One row per customer_id}\"]",
      "  caveats = []",
      "}"
    ],
    "description": "Create a DQL business term"
  },
  "Workbook": {
    "prefix": "dql-workbook",
    "body": [
      "workbook \"${1:Executive Review}\" {",
      "  page \"${2:Overview}\" {",
      "    layout(columns = 12) {",
      "      row {",
      "        chart.kpi(",
      "          SELECT SUM(${3:revenue}) as total FROM ${4:orders},",
      "          metrics = [\"total\"],",
      "          title = \"${5:Total Revenue}\"",
      "        ) span 12",
      "      }",
      "    }",
      "  }",
      "}"
    ],
    "description": "Create a workbook page skeleton"
  }
}
