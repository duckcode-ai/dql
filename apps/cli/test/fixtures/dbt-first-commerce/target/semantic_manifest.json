{
  "semantic_models": [
    {
      "name": "orders",
      "model": "ref('fct_orders')",
      "defaults": { "agg_time_dimension": "report_date" },
      "entities": [
        { "name": "order", "type": "primary", "expr": "order_id" },
        { "name": "customer", "type": "foreign", "expr": "customer_id" }
      ],
      "measures": [
        { "name": "gross_revenue_measure", "agg": "sum", "expr": "order_total", "agg_time_dimension": "report_date" }
      ],
      "dimensions": [
        { "name": "report_date", "type": "time", "type_params": { "time_granularity": "day" } }
      ]
    },
    {
      "name": "customers",
      "model": "ref('dim_customers')",
      "entities": [
        { "name": "customer", "type": "primary", "expr": "customer_id" }
      ],
      "measures": [],
      "dimensions": [
        { "name": "customer_name", "type": "categorical" }
      ]
    }
  ],
  "metrics": [
    {
      "name": "gross_revenue",
      "label": "Gross revenue",
      "description": "Completed-order revenue reported in the Commerce business timezone.",
      "type": "simple",
      "type_params": { "measure": { "name": "gross_revenue_measure" } }
    }
  ]
}
