// dql-format: 1

block "Runtime Parameter Acceptance" {
  domain = "commerce"
  type = "custom"
  status = "certified"
  description = "Verifies that certified typed values rerun consistently across Ask, Apps, Notebooks, Block Studio, CLI, and MCP."
  owner = "commerce@company.test"
  parameterPolicy {
    category = "dynamic"
    top_n = "dynamic"
  }
  params {
    category: string = "Beverage"
    top_n: number = 10
  }
  query = """
    SELECT
    ${category} AS selected_category,
    ${top_n} AS selected_limit
  """
}
