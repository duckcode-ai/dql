{
  "name": "@duckcodeailabs/dql-cli",
  "version": "1.2.2",
  "description": "Public CLI for parsing, formatting, testing, and certifying DQL blocks",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "dql": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b && node ./scripts/copy-runtime-assets.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "bench:manifest": "tsx bench/manifest-bench.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckcode-ai/dql.git",
    "directory": "apps/cli"
  },
  "dependencies": {
    "@duckcodeailabs/dql-compiler": "workspace:*",
    "@duckcodeailabs/dql-connectors": "workspace:*",
    "@duckcodeailabs/dql-core": "workspace:*",
    "@duckcodeailabs/dql-governance": "workspace:*",
    "@duckcodeailabs/dql-mcp": "workspace:*",
    "@duckcodeailabs/dql-notebook": "workspace:*",
    "@duckcodeailabs/dql-project": "workspace:*",
    "isomorphic-git": "^1.27.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
