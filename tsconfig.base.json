{
  "compilerOptions": {
    "target": "ES2022",
    "baseUrl": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@duckcodeailabs/dql-core": ["packages/dql-core/src/index.ts"],
      "@duckcodeailabs/dql-compiler": ["packages/dql-compiler/src/index.ts"],
      "@duckcodeailabs/dql-runtime": ["packages/dql-runtime/src/index.ts"],
      "@duckcodeailabs/dql-charts": ["packages/dql-charts/src/index.ts"],
      "@duckcodeailabs/dql-lsp": ["packages/dql-lsp/src/index.ts"],
      "@duckcodeailabs/dql-connectors": ["packages/dql-connectors/src/index.ts"],
      "@duckcodeailabs/dql-governance": ["packages/dql-governance/src/index.ts"],
      "@duckcodeailabs/dql-project": ["packages/dql-project/src/index.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true
  }
}
