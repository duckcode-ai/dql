{
  "name": "@duckcodeailabs/dql-core",
  "version": "0.10.1",
  "description": "DQL language core: lexer, parser, AST, semantic analysis",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "dql",
    "dashboard",
    "query",
    "language",
    "lexer",
    "parser",
    "ast"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckcode-ai/dql.git",
    "directory": "packages/dql-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "node-sql-parser": "^5.4.0"
  }
}
