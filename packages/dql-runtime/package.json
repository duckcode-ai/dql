{
  "name": "@duckcodeailabs/dql-runtime",
  "version": "0.8.11",
  "description": "DQL browser runtime: data fetching, Vega rendering, hot-reload client",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": "./dist/dql-runtime.browser.js",
    "./browser/min": "./dist/dql-runtime.browser.min.js",
    "./esm": "./dist/dql-runtime.esm.js"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc && node build.mjs",
    "build:types": "tsc",
    "build:bundle": "node build.mjs",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckcode-ai/dql.git",
    "directory": "packages/dql-runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
