{
  "name": "@duckcodeailabs/dql-compiler",
  "version": "1.3.4",
  "description": "DQL compiler: IR lowering, Vega-Lite code generation, HTML/CSS emitting",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckcode-ai/dql.git",
    "directory": "packages/dql-compiler"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@duckcodeailabs/dql-core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
