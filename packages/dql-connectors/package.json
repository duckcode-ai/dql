{
  "name": "@duckcodeailabs/dql-connectors",
  "version": "0.8.2",
  "description": "DQL database connectors for local files, SQL warehouses, and lakehouse engines",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckcode-ai/dql.git",
    "directory": "packages/dql-connectors"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.882.0",
    "@google-cloud/bigquery": "^7.5.0",
    "better-sqlite3": "^11.7.0",
    "duckdb": "^1.1.0",
    "mssql": "^11.0.0",
    "mysql2": "^3.9.0",
    "pg": "^8.13.0",
    "snowflake-sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
