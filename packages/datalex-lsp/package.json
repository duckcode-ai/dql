{
  "name": "@duckcodeailabs/datalex-lsp",
  "version": "0.2.0",
  "description": "DataLex Language Server Protocol implementation — schema-aware diagnostics for *.model.yaml files",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "datalex-lsp": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b && cp src/datalex-model.schema.json dist/datalex-model.schema.json",
    "test": "vitest run --passWithNoTests",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckcode-ai/dql.git",
    "directory": "packages/datalex-lsp"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "js-yaml": "^4.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
