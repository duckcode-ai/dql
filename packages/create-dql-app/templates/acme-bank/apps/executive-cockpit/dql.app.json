      "allowedRoles": ["viewer", "analyst", "owner"],
      "accessLevel": "execute",
      "enabled": true
    },
    {
      "id": "executive-cards-readthrough",
      "domain": "cards",
      "minClassification": "internal",
      "allowedRoles": ["viewer", "analyst", "owner"],
      "accessLevel": "execute",
      "enabled": true
    },
    {
      "id": "executive-deposits-readthrough",
      "domain": "deposits",
      "minClassification": "internal",
      "allowedRoles": ["viewer", "analyst", "owner"],
      "accessLevel": "execute",
      "enabled": true
    },
    {
      "id": "executive-lending-readthrough",
      "domain": "lending",
      "minClassification": "internal",
      "allowedRoles": ["viewer", "analyst", "owner"],
      "accessLevel": "execute",
      "enabled": true
    },
    {
      "id": "executive-owner-admin",
      "domain": "executive",
      "minClassification": "restricted",
      "allowedRoles": ["owner"],
      "accessLevel": "admin",
      "enabled": true
    }
  ],
  "rlsBindings": [],
